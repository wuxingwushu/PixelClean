#pragma once

#define PIXEL_PLATFORM "@PIXEL_PLATFORM@"

#if defined(_WIN32) || defined(_WIN64)
    #define PIXEL_PLATFORM_WIN 1
#elif defined(__ANDROID__)
    #define PIXEL_PLATFORM_ANDROID 1
#endif

#if PIXEL_PLATFORM_WIN
    #define win  1
#elif PIXEL_PLATFORM_ANDROID
    #define 安卓 1
#endif

#define PIXEL_HAS_GLFW @PIXEL_HAS_GLFW@

#if defined(__aarch64__) || defined(_M_ARM64)
    #define PIXEL_ARCH_ARM64   1
#elif defined(__x86_64__) || defined(_M_X64)
    #define PIXEL_ARCH_X64     1
#endif

#if PIXEL_PLATFORM_WIN
    #define PIXEL_HAS_CLIPBOARD    1
    #define PIXEL_HAS_CONSOLE      1
    #define PIXEL_HAS_FILE_DIALOG  1
    #define PIXEL_INPUT_KEYBOARD   1
#elif PIXEL_PLATFORM_ANDROID
    #define PIXEL_HAS_CLIPBOARD    1
    #define PIXEL_HAS_CONSOLE      0
    #define PIXEL_HAS_FILE_DIALOG  0
    #define PIXEL_INPUT_KEYBOARD   0
    #define PIXEL_INPUT_TOUCH      1
#endif

#if defined(NDEBUG)
    #define PIXEL_BUILD_RELEASE 1
#else
    #define PIXEL_BUILD_DEBUG   1
#endif